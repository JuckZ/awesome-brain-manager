{
  "name": "@repo/theme",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./styles": "./src/styles/index.scss"
  },
  "scripts": {
    "build": "sass src/styles/index.scss dist/styles.css",
    "dev": "sass --watch src/styles/index.scss dist/styles.css",
    "lint": "stylelint \"**/*.scss\""
  },
  "devDependencies": {
    "sass": "^1.67.0",
    "stylelint": "^15.10.3",
    "stylelint-config-standard-scss": "^11.0.0"
  }
}