{
  "name": "awesome-brain-manager",
  "version": "1.13.0",
  "description": "A plugin that tries to solve all the trivial problems most people usually encountered in obsidian.",
  "keywords": [
    "reminder",
    "notification",
    "ntfy",
    "awesome-brain-manager",
    "Obsidian-plugin",
    "Obsidian"
  ],
  "type": "module",
  "exports": "./main.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "d": "vite",
    "dev": "dotenvx run -- vite build -w",
    "build": "dotenvx run -- vite build",
    "build:check": "run-p type-check build",
    "preview": "vite preview",
    "test:w": "vitest --watch weather",
    "test": "vitest",
    "play": "playwright test main.spec.ts",
    "p": "playwright test electron.spec.ts",
    "t": "dotenvx run -- node test2.js",
    "test:unit": "vitest --environment jsdom --root src/",
    "test:e2e": "start-server-and-test preview :4173 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' :4173 'cypress open --e2e'",
    "test:coverage": "vitest run --coverage",
    "report:coverage": "pnpm run test:coverage && vitest --reporter=junit --outputFile=test-report.junit.xml",
    "update": "ncu -u",
    "type-check": "vue-tsc --noEmit -p tsconfig.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .eslintignore && tsc --noEmit --pretty",
    "commit": "git-cz",
    "up:yithub": "ncu -u -p pnpm @yithub/* && pnpm install",
    "format:check": "prettier --list-different {src,__mocks__,bin}/**/*.ts",
    "format:write": "prettier --write {src,__mocks__,bin}/**/*.ts",
    "start:help": "ts-node ./src/bin/order.bin.ts -h",
    "start:example": "ts-node ./src/bin/order.bin.ts pizza beer",
    "version": "node ../../version-bump.mjs",
    "prepare": "husky",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@codemirror/language": "^6.9.0",
    "@codemirror/state": "^6.2.1",
    "@codemirror/view": "^6.19.0",
    "@emoji-mart/data": "^1.1.2",
    "@repo/ui": "workspace:*",
    "@repo/utils": "workspace:*",
    "@types/markdown-it-container": "^2.0.8",
    "@vicons/ionicons5": "^0.12.0",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "chart.js": "^4.4.0",
    "commander": "^11.0.0",
    "cursor-effects": "^1.0.12",
    "emoji-mart": "^5.5.2",
    "i18next": "^23.6.0",
    "i18next-browser-languagedetector": "^7.1.0",
    "i18next-http-backend": "^2.3.0",
    "i18next-locize-backend": "^7.0.4",
    "i18next-vue": "^3.0.0",
    "interactjs": "^1.10.19",
    "jsonfile": "^6.1.0",
    "locize": "^4.0.14",
    "locize-lastused": "^4.0.2",
    "lodash-es": "^4.17.21",
    "markdown-it": "^13.0.2",
    "markdown-it-container": "^3.0.0",
    "naive-ui": "^2.34.4",
    "nanoid": "^5.0.2",
    "ora": "^7.0.1",
    "party-js": "^2.2.0",
    "patch-package": "^8.0.0",
    "pinia": "^2.1.6",
    "posthog-js": "^1.87.5",
    "rrule": "^2.7.2",
    "sql.js": "^1.8.0",
    "twemoji": "^14.0.2",
    "vue": "catalog:",
    "vue3-radial-progress": "^1.1.1"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.31.0",
    "@interactjs/types": "^1.10.19",
    "@playwright/test": "^1.39.0",
    "@rollup/plugin-node-resolve": "^15.2.1",
    "@types/jsdom": "^21.1.2",
    "@types/node": "^20.6.0",
    "@types/plantuml-encoder": "^1.4.0",
    "@types/sql.js": "^1.4.4",
    "@typescript-eslint/eslint-plugin": "6.7.0",
    "@typescript-eslint/parser": "6.7.0",
    "@vitejs/plugin-vue": "catalog:vite",
    "@vitejs/plugin-vue-jsx": "catalog:vite",
    "@vitest/coverage-v8": "^2.1.8",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.1",
    "@vue/tsconfig": "^0.4.0",
    "builtin-modules": "3.3.0",
    "compare-versions": "^6.1.0",
    "electron": "^33.2.1",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-vue": "^9.17.0",
    "jsdom": "^22.1.0",
    "npm-run-all": "^4.1.5",
    "obsidian": "catalog:obsidian",
    "obsidian-dataview": "catalog:obsidian",
    "obsidian-typings": "catalog:obsidian",
    "plantuml-encoder": "^1.4.0",
    "playwright": "^1.49.1",
    "rollup": "^3.29.1",
    "rollup-plugin-polyfill-node": "^0.12.0",
    "rollup-plugin-visualizer": "^5.9.2",
    "sass-embedded": "catalog:",
    "ts-node": "^10.9.1",
    "tslib": "2.6.2",
    "typescript": "5.2.2",
    "unocss": "catalog:",
    "uuid": "^9.0.1",
    "vite": "catalog:vite",
    "vite-plugin-static-copy": "^3.0.0",
    "vite-plugin-top-level-await": "^1.3.1",
    "vite-plugin-wasm": "^3.2.2",
    "vitest": "^2.1.8",
    "vue-tsc": "^1.8.11"
  }
}