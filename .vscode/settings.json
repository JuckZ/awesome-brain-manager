{
  "deno.enable": true,
  "typescript.tsdk": "node_modules\\typescript\\lib",
  "typescript.tsserver.log": "off",
  "editor.inlineSuggest.showToolbar": "onHover",
  "editor.defaultFormatter": "dbaeumer.vscode-eslint",
  "prettier.enable": false,
  "workbench.list.smoothScrolling": true,
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.cursorBlinking": "expand",
  "editor.stickyScroll.enabled": true,
  "editor.wordSeparators": "`~!@#%^&*()=+[{]}\\|;:'\",.<>/?",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit",
    "source.organizeImports": "never",
    // "source.fixAll": "always"
    "source.fixAll.markdownlint": "explicit",
    "source.fixAll.tslint": "explicit",
    "source.sortPackageJson": "never"
  },
  "files.exclude": {
    // "**/miniprogram_npm/": true,
    // "**/node_modules/": true
  },
  // "vue.complete.casing.props": "autoKebab",
  // "vue.format.script.initialIndent": true,
  // "vue.format.template.initialIndent": true,
  "vue.updateImportsOnFileMove.enabled": true,
  "vue.server.hybridMode": true,
  "[vue]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[javascript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[html]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[css]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[scss]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "javascript.inlayHints.functionLikeReturnTypes.enabled": true,
  "javascript.inlayHints.parameterTypes.enabled": true,
  "javascript.inlayHints.variableTypes.enabled": true,
  "css.validate": false,
  "less.validate": false,
  "scss.validate": false,
  "stylelint.enable": true,
  "stylelint.packageManager": "pnpm",
  "diffEditor.ignoreTrimWhitespace": false,
  "terminal.integrated.stickyScroll.enabled": true,
  "stylelint.snippet": [
    "css",
    "postcss",
    "scss",
    "html",
    "vue"
  ],
  "stylelint.validate": [
    "css",
    "postcss",
    "scss",
    "html",
    "vue"
  ],
  "eslint.options": {
    "flags": [
      "unstable_config_lookup_from_file"
    ]
  },
  "eslint.format.enable": true,
  // Silent the stylistic rules in you IDE, but still auto fix them
  "eslint.rules.customizations": [
    {
      "rule": "style/*",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "format/*",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "*-indent",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "*-spacing",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "*-spaces",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "*-order",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "*-dangle",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "*-newline",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "*quotes",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "*semi",
      "severity": "off",
      "fixable": true
    }
  ],
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  // Enable eslint for all supported languages
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue",
    "html",
    "markdown",
    "json",
    "json5",
    "jsonc",
    "yaml",
    "toml",
    "xml",
    "gql",
    "graphql",
    "astro",
    "css",
    "less",
    "scss",
    "pcss",
    "postcss"
  ],
  "cursor-retrieval.canAttemptGithubLogin": false,
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.git": true,
    "**/build": true,
    "**/coverage": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "stats.html": true,
    "types/components.d.ts": true
  }
}
