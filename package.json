{
  "name": "awesome-brain-manager-monorepo",
  "version": "1.13.0",
  "description": "A plugin that tries to solve all the trivial problems most people usually encountered in obsidian.",
  "private": true,
  "keywords": [
    "reminder",
    "notification",
    "ntfy",
    "awesome-brain-manager",
    "Obsidian-plugin",
    "Obsidian"
  ],
  "homepage": "https://github.com/JuckZ/awesome-brain-manager#readme",
  "bugs": {
    "url": "https://github.com/JuckZ/awesome-brain-manager/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:JuckZ/awesome-brain-manager.git"
  },
  "license": "MIT",
  "author": "Juck",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format:check": "prettier --list-different \"{apps,packages}/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:write": "prettier --write \"{apps,packages}/**/*.{ts,tsx,js,jsx,json,md}\"",
    "docs:dev": "turbo run docs:dev",
    "docs:build": "turbo run docs:build",
    "docs:preview": "turbo run docs:preview",
    "semantic-release": "semantic-release",
    "version": "node version-bump.mjs",
    "prepare": "husky"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -e $GIT_PARAMS"
    }
  },
  "lint-staged": {
    "{apps,packages}/**/*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "git add"
    ]
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/prompt"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^17.7.1",
    "@commitlint/config-conventional": "^17.7.0",
    "@commitlint/prompt": "^17.7.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^10.0.4",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^9.0.6",
    "@semantic-release/npm": "^10.0.6",
    "@semantic-release/release-notes-generator": "^11.0.7",
    "commitizen": "^4.3.0",
    "husky": "catalog:dev-tools",
    "lint-staged": "catalog:dev-tools",
    "prettier": "^3.0.3",
    "semantic-release": "^21.1.1",
    "turbo": "catalog:dev-tools"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=14.16"
  }
}